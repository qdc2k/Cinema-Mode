## Ignore Visual Studio temporary files, build results, and files generated by popular Visual Studio extensions.

# Build artifacts
bin/
obj/

# Visual Studio cache/options
.vs/

# Visual Studio Code
.vscode/

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Rider
.idea/
*.sln.iml

# Local nuget packages
*.nupkg
*.snupkg

# Compiled binaries
*.exe

# Generated files
*.g.cs
*.baml
