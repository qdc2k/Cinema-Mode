<Window x:Class="CinemaMode.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cinema Mode"
        Height="180"
        Width="220"
        Background="#1A1A1A"
        Foreground="#FFF"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        StateChanged="Window_StateChanged">

    <Window.Resources>
        <Style x:Key="StatusButtonStyle"
               TargetType="ToggleButton">
            <Setter Property="FontSize"
                    Value="16"/>
            <Setter Property="FontWeight"
                    Value="SemiBold"/>
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border"
                                CornerRadius="12"
                                Background="#E74C3C"
                                BorderThickness="0"
                                Padding="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="20,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked"
                                     Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#27AE60"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="border"
                                        Property="Opacity"
                                        Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked"
                         Value="True">
                    <Setter Property="Content"
                            Value="ON"/>
                </Trigger>
                <Trigger Property="IsChecked"
                         Value="False">
                    <Setter Property="Content"
                            Value="OFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="#1A1A1A"
            CornerRadius="15"
            BorderBrush="#333"
            BorderThickness="1"
            ToolTip="Minimize to tray.">
        <Grid>
            <!-- Title Bar -->
            <Grid Height="50"
                  VerticalAlignment="Top"
                  Background="#252525">
                <TextBlock Text="Cinema Mode"
                           VerticalAlignment="Center"
                           Margin="20,0"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="White"/>

                <!-- Minimize Button -->
                <Button Content="−"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        Foreground="#888"
                        BorderThickness="0"
                        Margin="0,0,50,0"
                        Width="30"
                        Height="30"
                        FontSize="18"
                        ToolTip="Minimize to tray."
                        Click="Minimize_Click"
                        Cursor="Hand"/>

                <!-- Close Button -->
                <Button Content="✕"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        Foreground="#888"
                        BorderThickness="0"
                        Margin="0,0,15,0"
                        Width="30"
                        Height="30"
                        FontSize="16"
                        ToolTip="Close the program."
                        Click="Close_Click"
                        Cursor="Hand"/>
            </Grid>

            <!-- Content Area -->
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Margin="0,25,0,0">
                <ToggleButton x:Name="ModeToggle"
                              Height="50"
                              Checked="ModeToggle_Checked"
                              Unchecked="ModeToggle_Unchecked"
                              Style="{StaticResource StatusButtonStyle}"
                              ToolTip="Toggle Cinema Mode on/off"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
