<Window x:Class="CinemaMode.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cinema Mode"
        Height="250"
        Width="230"
        Background="#1A1A1A"
        Foreground="#FFF"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        StateChanged="Window_StateChanged"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style x:Key="StatusButtonStyle"
               TargetType="ToggleButton">
            <Setter Property="FontSize"
                    Value="16"/>
            <Setter Property="FontWeight"
                    Value="SemiBold"/>
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border"
                                CornerRadius="12"
                                Background="#E74C3C"
                                BorderThickness="0"
                                Padding="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="20,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked"
                                     Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#27AE60"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="border"
                                        Property="Opacity"
                                        Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked"
                         Value="True">
                    <Setter Property="Content"
                            Value="ON"/>
                </Trigger>
                <Trigger Property="IsChecked"
                         Value="False">
                    <Setter Property="Content"
                            Value="OFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Custom Slider Style for gradient track -->
        <Style TargetType="{x:Type Slider}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Slider}">
                        <Grid>
                            <Border x:Name="PART_TrackBackground"
                                    Height="4"
                                    CornerRadius="2"
                                    VerticalAlignment="Center">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0"
                                                         EndPoint="1,0">
                                        <GradientStop Color="#333"
                                                      Offset="0.0"/>
                                        <!-- Dark on left -->
                                        <GradientStop Color="#BBB"
                                                      Offset="1.0"/>
                                        <!-- Bright on right -->
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb"
                                           Width="14"
                                           Height="14">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Ellipse Fill="White"
                                                         Stroke="#333"
                                                         StrokeThickness="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#1A1A1A"
            CornerRadius="15"
            BorderBrush="#333"
            BorderThickness="1">
        <Grid>
            <!-- Title Bar -->
            <Grid Height="45"
                  VerticalAlignment="Top"
                  Background="#252525">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="12,0">
                    <Image x:Name="AppIconImg"
                           Width="20"
                           Height="20"
                           Margin="0,0,8,0"/>
                    <TextBlock Text="Cinema Mode"
                               FontSize="15"
                               FontWeight="Bold">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0"
                                                 EndPoint="1,0">
                                <GradientStop Color="#9370DB"
                                              Offset="0.0"/>
                                <!-- Light Purple -->
                                <GradientStop Color="#6A5ACD"
                                              Offset="0.5"/>
                                <!-- Darker Purple -->
                                <GradientStop Color="#4169E1"
                                              Offset="1.0"/>
                                <!-- Blue -->
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                </StackPanel>

                <!-- Minimize Button -->
                <Button Content="−"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        Foreground="#888"
                        BorderThickness="0"
                        Margin="0,0,44,0"
                        Width="30"
                        Height="30"
                        FontSize="18"
                        ToolTip="Minimize to tray."
                        Click="Minimize_Click"
                        Cursor="Hand"/>

                <!-- Close Button -->
                <Button Content="✕"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        Foreground="#888"
                        BorderThickness="0"
                        Margin="0,0,10,0"
                        Width="30"
                        Height="30"
                        FontSize="16"
                        ToolTip="Close the program."
                        Click="Close_Click"
                        Cursor="Hand"/>
            </Grid>

            <!-- Content Area -->
            <StackPanel VerticalAlignment="Top"
                        HorizontalAlignment="Center"
                        Margin="0,65,0,0"
                        Width="180">
                <ToggleButton x:Name="ModeToggle"
                              Height="30"
                              Width="180"
                              Margin="0,0,0,20"
                              Checked="ModeToggle_Checked"
                              Unchecked="ModeToggle_Unchecked"
                              Style="{StaticResource StatusButtonStyle}"
                              ToolTip="Toggle Cinema Mode on/off"
                              HorizontalAlignment="Center"/>

                <CheckBox x:Name="StartMinimizedCheck"
                          Content="Start Minimized"
                          Foreground="White"
                          Margin="0,0,0,10"
                          FontSize="12"
                          Checked="SettingChanged"
                          Unchecked="SettingChanged"
                          ToolTip="The application will start hidden in the system tray."/>

                <CheckBox x:Name="StartWithWindowsCheck"
                          Content="Start with Windows"
                          Foreground="White"
                          Margin="0,0,0,10"
                          FontSize="12"
                          Checked="SettingChanged"
                          Unchecked="SettingChanged"
                          ToolTip="Automatically launch the app when you log into Windows."/>

                <CheckBox x:Name="DimModeCheck"
                          Content="Just dim other screens"
                          Foreground="White"
                          Margin="0,0,0,18"
                          FontSize="12"
                          Checked="SettingChanged"
                          Unchecked="SettingChanged"
                          ToolTip="Uses a dark overlay on other screens instead of disabling them via Windows settings."/>

                <TextBlock Text="{Binding Value, ElementName=BrightnessSlider, StringFormat=Brightness: {0:0}%}"
                           Foreground="White"
                           FontSize="12"
                           Margin="0,0,0,2"
                           HorizontalAlignment="Center"/>
                <Slider x:Name="BrightnessSlider"
                        Width="180"
                        Minimum="0"
                        Maximum="100"
                        Value="10"
                        IsEnabled="{Binding IsChecked, ElementName=DimModeCheck}"
                        ValueChanged="SettingChanged"
                        ToolTip="Adjust how dark the other screens become."/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
