<Window x:Class="CinemaMode.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cinema Mode" Height="250" Width="400" 
        Background="#1A1A1A" Foreground="White"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True">
    
    <Window.Resources>
        <Style x:Key="ModernToggleStyle" TargetType="ToggleButton">
            <Setter Property="Content" Value="OFF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" CornerRadius="20" Background="#333" BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0078D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Content" Value="ON"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border CornerRadius="15" Background="#252525" BorderBrush="#333" BorderThickness="1">
        <Grid>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Cinema Mode" FontSize="28" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                <TextBlock Text="Automatic Screen Blackout" Foreground="#888" Margin="0,0,0,30" HorizontalAlignment="Center"/>
                
                <ToggleButton x:Name="ModeToggle" Width="120" Height="40" 
                              Checked="ModeToggle_Checked" Unchecked="ModeToggle_Unchecked"
                              Style="{StaticResource ModernToggleStyle}"/>
            </StackPanel>
            
            <!-- Close Button -->
            <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" 
                    Background="Transparent" Foreground="Gray" BorderThickness="0" 
                    Margin="10" Click="Close_Click"/>
        </Grid>
    </Border>
</Window>
